   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "marks = [45, 50, 52, 55, 60, 62, 65, 70, 72, 75, 80, 82, 85, 90, 95]\n",
    "\n",
    "plt.figure(figsize=(8,5))\n",
    "\n",
    "plt.hist(marks, bins=10, edgecolor=\"black\")\n",
    "\n",
    "plt.title(\"Marks Distribution\")\n",
    "plt.xlabel(\"Marks\")\n",
    "plt.ylabel(\"Frequency\")\n",
    "\n",
    "plt.show()"
   ]
